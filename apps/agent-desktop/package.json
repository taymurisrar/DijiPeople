{
  "name": "agent-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build:renderer && tsc -w",
    "build": "npm run clean && npm run build:main && npm run build:renderer && npm run copy:renderer",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "tsc src/renderer/login.ts --target ES2020 --module ES2020 --moduleResolution bundler --outDir src/renderer --skipLibCheck",
    "copy:renderer": "node scripts/copy-renderer.mjs",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('src/renderer/login.js',{force:true});\"",
    "start": "electron .",
    "dist:win": "npm run build && electron-builder --win nsis",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.6.2",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "electron": "39.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.2"
  }
}
