NODE_ENV=development
AGENT_APP_NAME=DijiPeople Agent
AGENT_API_BASE_URL=http://localhost:4000/api
AGENT_API_ORIGIN=http://localhost:4000
AGENT_APP_VERSION=1.0.0
AGENT_DEVICE_REGISTRATION_ENABLED=true
AGENT_ACCESS_TOKEN_TTL=15m
AGENT_REFRESH_TOKEN_TTL=8h
AGENT_SESSION_IDLE_TIMEOUT_SECONDS=28800
AGENT_SESSION_ABSOLUTE_TIMEOUT_SECONDS=2592000
AGENT_SESSION_REFRESH_THRESHOLD_SECONDS=300
AGENT_HEARTBEAT_INTERVAL_SECONDS=60
AGENT_HEARTBEAT_BATCH_SIZE=1000
AGENT_OFFLINE_QUEUE_ENABLED=true
AGENT_OFFLINE_QUEUE_MAX_ITEMS=5000
AGENT_ACTIVE_APP_TRACKING_ENABLED=true
AGENT_WINDOW_TITLE_TRACKING_ENABLED=true
AGENT_TRAY_STATUS_ENABLED=true
DIJIPEOPLE_AGENT_UPDATE_URL=http://localhost:4000/api/agent/updates
AGENT_AUTO_UPDATE_ENABLED=false
