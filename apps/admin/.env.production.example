NODE_ENV=production
NEXT_PUBLIC_APP_NAME=DijiPeople Admin
NEXT_PUBLIC_APP_ORIGIN=https://diji-people-admin.vercel.app
NEXT_PUBLIC_ADMIN_APP_URL=https://diji-people-admin.vercel.app
NEXT_PUBLIC_WEB_APP_URL=https://diji-people-web.vercel.app
NEXT_PUBLIC_LANDING_APP_URL=https://diji-people-landing.vercel.app
NEXT_PUBLIC_API_BASE_URL=https://dijipeople.onrender.com/api
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=
NEXT_PUBLIC_WEB_ROOT_DOMAIN=your-root-domain.com
NEXT_PUBLIC_ADMIN_ROOT_DOMAIN=admin.your-root-domain.com
API_BASE_URL=https://dijipeople.onrender.com/api
API_ORIGIN=https://dijipeople.onrender.com
ADMIN_ACCESS_TOKEN_COOKIE=admin_access_token
ADMIN_REFRESH_TOKEN_COOKIE=admin_refresh_token
ADMIN_SESSION_COOKIE=dp_admin_session_id
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_HTTP_ONLY=true
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_PATH=/
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_ABSOLUTE_TIMEOUT_SECONDS=2592000
SESSION_REFRESH_THRESHOLD_SECONDS=300
EXPOSE_DEV_AUTH_LINKS=false




NODE_ENV=production
APP_ENV=production

NEXT_PUBLIC_API_BASE_URL=https://dijipeople.onrender.com/api

NEXT_PUBLIC_ADMIN_URL=https://diji-people-admin.vercel.app
NEXT_PUBLIC_WEB_URL=https://diji-people-web.vercel.app
NEXT_PUBLIC_LANDING_URL=https://diji-people-landing.vercel.app

NEXT_PUBLIC_SESSION_WARNING_SECONDS=120
NEXT_PUBLIC_SESSION_ACTIVITY_THROTTLE_SECONDS=60
NEXT_PUBLIC_ENABLE_SESSION_WARNING_MODAL=true

NEXT_PUBLIC_SUPPORT_ERROR_MESSAGE=Something went wrong. Please contact support with the reference ID.

AUTH_COOKIE_ACCESS_NAME=dp_access_token
AUTH_COOKIE_REFRESH_NAME=dp_refresh_token
AUTH_COOKIE_SESSION_NAME=dp_session_id

AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_HTTP_ONLY=true
AUTH_COOKIE_PATH=/

ADMIN_ACCESS_TOKEN_COOKIE=admin_access_token
ADMIN_REFRESH_TOKEN_COOKIE=admin_refresh_token
ADMIN_SESSION_COOKIE=dp_admin_session_id
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_ABSOLUTE_TIMEOUT_SECONDS=2592000
SESSION_REFRESH_THRESHOLD_SECONDS=300
EXPOSE_DEV_AUTH_LINKS=false
