NODE_ENV=development
NEXT_PUBLIC_APP_NAME=DijiPeople Admin
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3002
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3002
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3001
NEXT_PUBLIC_LANDING_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=
NEXT_PUBLIC_WEB_ROOT_DOMAIN=localhost:3000
NEXT_PUBLIC_ADMIN_ROOT_DOMAIN=localhost:3002

API_BASE_URL=http://localhost:4000/api
API_ORIGIN=http://localhost:4000

ADMIN_ACCESS_TOKEN_COOKIE=admin_access_token
ADMIN_REFRESH_TOKEN_COOKIE=admin_refresh_token
ADMIN_SESSION_COOKIE=dp_admin_session_id
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HTTP_ONLY=true
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_PATH=/
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000

SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_ABSOLUTE_TIMEOUT_SECONDS=2592000
SESSION_REFRESH_THRESHOLD_SECONDS=300

EXPOSE_DEV_AUTH_LINKS=true
