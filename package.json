{
  "name": "dijipeople",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:landing": "npm --workspace landing run dev",
    "dev:web": "npm --workspace web run dev",
    "dev:admin": "npm --workspace admin run dev",
    "dev:api": "npm --workspace api run start:dev",
    "bootstrap:admin": "npm --workspace api run seed:admin",
    "release:api": "npm --workspace api run release",
    "release:web": "npm --workspace web run release",
    "release:admin": "npm --workspace admin run release",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  }
}
