  INVITED
  DISABLED
}

enum UserInvitationStatus {
  PENDING
  CONSUMED
  REVOKED
  EXPIRED
}

enum EmployeeEmploymentStatus {
  ACTIVE
  PROBATION
  NOTICE
  TERMINATED
}

enum EmployeeRecordType {
  INTERNAL_EMPLOYEE
  EXTERNAL_WORKER
  CONTRACTOR
}

enum EmployeeType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  CONSULTANT
}

enum EmployeeWorkMode {
  OFFICE
  REMOTE
  HYBRID
}

enum EmployeeContractType {
  PERMANENT
  FIXED_TERM
  FREELANCE
  TEMPORARY
}

enum EmployeeGender {
  FEMALE
  MALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum EmployeeMaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
}

enum LeaveAccrualType {
  FIXED_ANNUAL
  MONTHLY_ACCRUAL
  NONE
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
  CANCELLED
}

enum ApprovalActorType {
  MANAGER
  HR
}

enum WorkWeekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AttendanceEntryStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
  MISSED_CHECK_OUT
  ON_LEAVE
}

enum AttendanceMode {
  OFFICE
  REMOTE
  HYBRID
  MACHINE
  MANUAL
}

enum AttendanceEntrySource {
  MANUAL
  SYSTEM
  IMPORT
  MACHINE
  INTEGRATION
}

enum AttendanceImportBatchStatus {
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

enum TimesheetImportBatchStatus {
  PREVIEWED
  PROCESSING
  COMPLETED
  FAILED
}

enum AttendanceIntegrationType {
  API_PUSH
  FILE_IMPORT
  MACHINE_SYNC
  WEBHOOK
  MANUAL
  BROWSER
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum TimesheetEntryType {
  ON_WORK
  ON_LEAVE
  WEEKEND
  HOLIDAY
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum JobOpeningStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
  FILLED
  CANCELLED
}

enum RecruitmentStage {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEW
  FINAL_REVIEW
  OFFER
  APPROVED
  HIRED
  REJECTED
  ON_HOLD
  WITHDRAWN
}

enum DocumentOwnerType {
  CANDIDATE
  EMPLOYEE
}

enum DocumentParsingStatus {
  PENDING
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
}

enum CandidateIdentityType {
  EMAIL
  PHONE
  LINKEDIN
  NATIONAL_ID
}

enum CandidateHistoryReason {
  REUPLOAD
  MERGE
  PROFILE_UPDATE
  PARSE_UPDATE
  MANUAL_UPDATE
}

enum ApplicationHistoryReason {
  REAPPLY
  STAGE_CHANGE
  MATCH_RECALCULATION
  MANUAL_EDIT
  DUPLICATE_RESOLUTION
}

enum OnboardingStatus {
  DRAFT
  NOT_STARTED
  IN_PROGRESS
  AWAITING_CANDIDATE_INPUT
  READY_FOR_CONVERSION
  BLOCKED
  COMPLETED
  CANCELLED
}

enum OnboardingTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PayrollCycleStatus {
  DRAFT
  PROCESSING
  REVIEW
  FINALIZED
}

enum PayrollRecordStatus {
  DRAFT
  REVIEWED
  FINALIZED
}

enum SalaryComponentType {
  EARNING
  DEDUCTION
}

enum PayFrequency {
  MONTHLY
  SEMI_MONTHLY
  BI_WEEKLY
  WEEKLY
}

enum PayrollStatus {
  ACTIVE
  ON_HOLD
  STOPPED
}

enum RoleAccessLevel {
  USER
  BUSINESS_UNIT
  PARENT_BU
  ORGANIZATION
  TENANT
}

enum RoleType {
  SYSTEM
  CUSTOM
}

enum SecurityAccessLevel {
  NONE
  USER
  BUSINESS_UNIT
  PARENT_CHILD_BUSINESS_UNITS
  ORGANIZATION
  TENANT
}

enum SecurityPrivilege {
  READ
  CREATE
  WRITE
  DELETE
  ASSIGN
  SHARE
  APPEND
  IMPORT
  EXPORT
  APPROVE
  REJECT
  MANAGE
  CONFIGURE
}

enum PaymentMode {
  BANK_TRANSFER
  CASH
  CHECK
  OTHER
}

enum BusinessUnitType {
  INTERNAL
  EXTERNAL_ORGANIZATION
  BRANCH
  DEPARTMENT
  COST_CENTER
}

enum ProcessingCycleType {
  MONTHLY
  WEEKLY
  BIWEEKLY
  SEMI_MONTHLY
  CUSTOM
}

enum ProcessingCycleStatus {
  OPEN
  DATA_IMPORTED
  VALIDATION_FAILED
  SUBMITTED
  APPROVED
  PAYROLL_READY
  PAYROLL_GENERATED
  EXPORTED
  LOCKED
}

model Tenant {
  id              String           @id @default(uuid())
  customerAccountId String
  ownerUserId     String?
  name            String
  slug            String           @unique
  status          TenantStatus     @default(ACTIVE)
  subStatus       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     String?
  updatedById     String?
  users           User[]
  roles           Role[]
  permissions     Permission[]
  userPermissions UserPermission[]
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  rolePrivileges  RolePrivilege[]
  roleMiscPermissions RoleMiscPermission[]
  refreshTokens   RefreshToken[]
  userInvitations UserInvitation[]
  employees       Employee[]
  employeeEducationRecords EmployeeEducation[]
  employeeHistoryRecords EmployeeHistory[]
  employeePreviousEmployments EmployeePreviousEmployment[]
  departments     Department[]
  organizations   Organization[]
  businessUnits   BusinessUnit[]
  designations    Designation[]
  locations       Location[]
  emergencyContacts EmergencyContact[]
  employeeDocumentReferences EmployeeDocumentReference[]
  leaveTypes       LeaveType[]
  leavePolicies    LeavePolicy[]
  leaveRequests    LeaveRequest[]
  leaveApprovalSteps LeaveApprovalStep[]
  approvalMatrices ApprovalMatrix[]
  workSchedules    WorkSchedule[]
  attendanceEntries AttendanceEntry[]
  attendancePolicy AttendancePolicy?
  attendanceImportBatches AttendanceImportBatch[]
  attendanceIntegrationConfigs AttendanceIntegrationConfig[]
  holidayCalendars HolidayCalendar[]
  timesheets       Timesheet[]
  timesheetEntries TimesheetEntry[]
  timesheetImportBatches TimesheetImportBatch[]
  processingCycles ProcessingCycle[]
  projects         Project[]
  projectAssignments ProjectAssignment[]
  jobOpenings      JobOpening[]
  candidates       Candidate[]
  candidateIdentities CandidateIdentity[]
  candidateHistoryRecords CandidateHistory[]
  candidateEducationRecords CandidateEducation[]
  candidateExperienceRecords CandidateExperience[]
  candidateEvaluations CandidateEvaluation[]
  applications     Application[]
  applicationHistoryRecords ApplicationHistory[]
  applicationStageHistoryRecords ApplicationStageHistory[]
  documentReferences DocumentReference[]
  documentParsingJobs DocumentParsingJob[]
  onboardingTemplates OnboardingTemplate[]
  employeeOnboardings EmployeeOnboarding[]
  onboardingTasks      OnboardingTask[]
  payrollCycles        PayrollCycle[]
  payrollRecords       PayrollRecord[]
  salaryComponents     SalaryComponent[]
  employeeCompensations EmployeeCompensation[]
  auditLogs           AuditLog[]
  documents           Document[]
  documentLinks       DocumentLink[]
  tenantSettings      TenantSetting[]
  tenantFeatures      TenantFeature[]
  customizationTables CustomizationTable[]
  customizationColumns CustomizationColumn[]
  customizationViews CustomizationView[]
  customizationForms  CustomizationForm[]
  customizationPublishSnapshots CustomizationPublishSnapshot[]
  subscription        Subscription?
  customerAccount     CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Restrict)
  customerOnboardings CustomerOnboarding[]
  invoices            Invoice[]
  payments            Payment[]
  plans               Plan[]
  planFeatures        PlanFeature[]
  documentTypes       DocumentType[]
  documentCategories  DocumentCategory[]
  relationTypes       RelationType[]
  ownerUser         User?          @relation("TenantOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([customerAccountId])
  @@index([ownerUserId])
}

model CustomerAccount {
  id                String               @id @default(uuid())
  companyName       String
  legalCompanyName  String?
  primaryContactFirstName String?
  primaryContactLastName String?
  primaryContactEmail String?
  primaryContactPhone String?
  billingContactEmail String?
  financeContactName String?
  financeContactEmail String?
  industry          String?
  companySize       String?
  contactEmail      String
  contactPhone      String?
  country           String
  stateProvince     String?
  city              String?
  addressLine1      String?
  addressLine2      String?
  website           String?
  estimatedEmployeeCount Int?
  actualEmployeeCount Int?
  selectedPlanId    String?
  preferredBillingCycle BillingCycle?
  customPricingFlag Boolean @default(false)
  discountApproved  Boolean @default(false)
  leadId            String?
  status            CustomerAccountStatus @default(LEAD)
  subStatus         String?
  assignedToUserId  String?
  accountManagerUserId String?
  primaryOwnerUserId String?
  stripeCustomerId  String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  assignedToUser    User?                @relation("AssignedCustomerAccounts", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  accountManagerUser User?               @relation("ManagedCustomerAccounts", fields: [accountManagerUserId], references: [id], onDelete: SetNull)
  primaryOwnerUser  User?                @relation("OwnedCustomerAccounts", fields: [primaryOwnerUserId], references: [id], onDelete: SetNull)
  tenants           Tenant[]
  selectedPlan      Plan?                @relation("SelectedCustomerPlan", fields: [selectedPlanId], references: [id], onDelete: SetNull)
  sourceLead        Lead?                @relation("LeadToCustomer", fields: [leadId], references: [id], onDelete: SetNull)
  contacts          CustomerContact[]
  notes             CustomerNote[]
  onboardings       CustomerOnboarding[]

  @@index([status])
  @@index([subStatus])
  @@index([assignedToUserId])
  @@index([accountManagerUserId])
  @@index([primaryOwnerUserId])
  @@index([leadId])
  @@index([selectedPlanId])
}

model CustomerContact {
  id                String          @id @default(uuid())
  customerAccountId String
  name              String
  email             String
  role              String
  isPrimaryContact  Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  @@index([customerAccountId])
  @@index([customerAccountId, isPrimaryContact])
}

model CustomerNote {
  id                String          @id @default(uuid())
  customerAccountId String
  note              String
  createdByUserId   String?
  createdAt         DateTime        @default(now())
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  createdByUser     User?           @relation("CustomerNotes", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([customerAccountId, createdAt])
}

model Lead {
  id             String     @id @default(uuid())
  contactFirstName String?
  contactLastName String?
  fullName       String
  companyName    String
  workEmail      String
  phoneNumber    String?
  companyWebsite String?
  industry       String
  companySize    String
  country        String?
  stateProvince  String?
  city           String?
  estimatedEmployeeCount Int?
  expectedGoLiveDate DateTime?
  budgetExpectation String?
  requirementsSummary String?
  notes          String?
  assignedToUserId String?
  subStatus      String?
  isQualified    Boolean    @default(false)
  convertedAt    DateTime?
  message        String?
  interestedPlan String?
  source         String
  status         LeadStatus @default(NEW)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  assignedToUser User?      @relation("AssignedLeads", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  convertedCustomers CustomerAccount[] @relation("LeadToCustomer")
  onboardings    CustomerOnboarding[]

  @@index([status, createdAt])
  @@index([subStatus, createdAt])
  @@index([workEmail])
  @@index([companyName])
  @@index([source, createdAt])
  @@index([assignedToUserId])
}

model CustomerOnboarding {
  id                       String                   @id @default(uuid())
  customerId               String
  leadId                   String?
  tenantId                 String?                  @unique
  onboardingOwnerUserId    String?
  selectedPlanId           String?
  billingCycle             BillingCycle?
  agreedPrice              Decimal?                 @db.Decimal(12, 2)
  discountType             DiscountType             @default(NONE)
  discountValue            Decimal                  @default(0) @db.Decimal(12, 2)
  featureSelectionSummary  Json?
  primaryOwnerFirstName    String
  primaryOwnerLastName     String
  primaryOwnerWorkEmail    String
  primaryOwnerPhone        String?
  createServiceAccount     Boolean                  @default(false)
  serviceAccountDisplayName String?
  serviceAccountAssignSystemAdmin Boolean           @default(true)
  serviceAccountEmail      String?
  contractSigned           Boolean                  @default(false)
  paymentConfirmed         Boolean                  @default(false)
  implementationKickoffDone Boolean                 @default(false)
  dataReceived             Boolean                  @default(false)
  configurationReady       Boolean                  @default(false)
  trainingPlanned          Boolean                  @default(false)
  tenantCreated            Boolean                  @default(false)
  notes                    String?
  status                   CustomerOnboardingStatus @default(NOT_STARTED)
  subStatus                String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  customer                 CustomerAccount          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead                     Lead?                    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  tenant                   Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  onboardingOwnerUser      User?                    @relation("OwnedCustomerOnboardings", fields: [onboardingOwnerUserId], references: [id], onDelete: SetNull)
  selectedPlan             Plan?                    @relation("SelectedOnboardingPlan", fields: [selectedPlanId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([leadId])
  @@index([status])
  @@index([subStatus])
  @@index([onboardingOwnerUserId])
  @@index([selectedPlanId])
}

model Country {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  states      StateProvince[]
  cities      City[]
  employees   Employee[]

  @@index([isActive, sortOrder])
  @@index([name])
}

model StateProvince {
  id          String   @id @default(uuid())
  countryId   String
  code        String
  name        String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  cities      City[]
  employees   Employee[]

  @@unique([countryId, code])
  @@unique([countryId, name])
  @@index([countryId, isActive, sortOrder])
}

model City {
  id              String         @id @default(uuid())
  countryId       String
  stateProvinceId String?
  name            String
  isActive        Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  country         Country        @relation(fields: [countryId], references: [id], onDelete: Cascade)
  stateProvince   StateProvince? @relation(fields: [stateProvinceId], references: [id], onDelete: SetNull)
  employees       Employee[]

  @@unique([countryId, stateProvinceId, name])
  @@index([countryId, stateProvinceId, isActive, sortOrder])
}

model Plan {
  id          String        @id @default(uuid())
  tenantId    String?
  key         String        @unique
  name        String
  description String?
  isActive    Boolean       @default(true)
  monthlyBasePrice Decimal  @default(0) @db.Decimal(12, 2)
  annualBasePrice  Decimal  @default(0) @db.Decimal(12, 2)
  currency         String   @default("USD")
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById String?
  updatedById String?
  tenant      Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  features    PlanFeature[]
  subscriptions Subscription[]
  selectedByCustomers CustomerAccount[] @relation("SelectedCustomerPlan")
  selectedByOnboardings CustomerOnboarding[] @relation("SelectedOnboardingPlan")

  @@index([tenantId])
  @@index([isActive, sortOrder])
}

model PlanFeature {
  id          String   @id @default(uuid())
  tenantId    String?
  planId      String
  featureKey  String
  isEnabled   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([tenantId])
  @@index([planId])
  @@index([featureKey, isEnabled])
}

model Subscription {
  id          String             @id @default(uuid())
  tenantId    String             @unique
  planId      String
  billingCycle BillingCycle      @default(MONTHLY)
  basePrice   Decimal            @default(0) @db.Decimal(12, 2)
  discountType DiscountType      @default(NONE)
  discountValue Decimal          @default(0) @db.Decimal(12, 2)
  discountReason String?
  finalPrice  Decimal            @default(0) @db.Decimal(12, 2)
  currency    String             @default("USD")
  status      SubscriptionStatus @default(TRIALING)
  startDate   DateTime
  endDate     DateTime?
  renewalDate DateTime?
  autoRenew   Boolean            @default(true)
  stripeSubscriptionId String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdById String?
  updatedById String?
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan        Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices    Invoice[]
  payments    Payment[]

  @@index([status])
  @@index([planId, status])
}

model User {
  id            String         @id @default(uuid())
  tenantId      String
  businessUnitId String
  firstName     String
  lastName      String
  email         String         @unique
  passwordHash  String
  status        UserStatus     @default(ACTIVE)
  isServiceAccount Boolean     @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdById   String?
  updatedById   String?
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessUnit  BusinessUnit   @relation(fields: [businessUnitId, tenantId], references: [id, tenantId], onDelete: Restrict)
  userRoles     UserRole[]
  userPermissions UserPermission[]
  refreshTokens RefreshToken[]
  invitations   UserInvitation[]
  employee      Employee?
  leaveApprovalSteps LeaveApprovalStep[]
  approvedTimesheets Timesheet[] @relation("TimesheetApprover")
  lockedProcessingCycles ProcessingCycle[] @relation("ProcessingCycleLocker")
  assignedOnboardingTasks OnboardingTask[] @relation("OnboardingTaskAssignee")
  uploadedDocuments  Document[] @relation("UploadedDocuments")
  auditLogs          AuditLog[] @relation("AuditLogActor")
  assignedCustomerAccounts CustomerAccount[] @relation("AssignedCustomerAccounts")
  managedCustomerAccounts  CustomerAccount[] @relation("ManagedCustomerAccounts")
  ownedCustomerAccounts    CustomerAccount[] @relation("OwnedCustomerAccounts")
  customerNotes            CustomerNote[]    @relation("CustomerNotes")
  assignedLeads            Lead[]            @relation("AssignedLeads")
  ownedCustomerOnboardings CustomerOnboarding[] @relation("OwnedCustomerOnboardings")
  ownedTenants      Tenant[]                    @relation("TenantOwner")

  @@index([tenantId])
  @@index([businessUnitId])
  @@index([tenantId, status])
  @@index([tenantId, lastName, firstName])
}

model Organization {
  id                   String         @id @default(uuid())
  tenantId             String
  name                 String
  parentOrganizationId String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentOrganization   Organization?  @relation("OrganizationHierarchy", fields: [parentOrganizationId, tenantId], references: [id, tenantId], onDelete: Restrict)
  childOrganizations   Organization[] @relation("OrganizationHierarchy")
  businessUnits        BusinessUnit[]

  @@unique([id, tenantId])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, parentOrganizationId])
}

model BusinessUnit {
  id                   String         @id @default(uuid())
  tenantId             String
  name                 String
  organizationId       String
  parentBusinessUnitId String?
  type                 BusinessUnitType @default(INTERNAL)
  settingsJson         Json?
  payrollContactName   String?
  payrollContactEmail  String?
  payrollContactPhone  String?
  approvalContactName  String?
  approvalContactEmail String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization         Organization   @relation(fields: [organizationId, tenantId], references: [id, tenantId], onDelete: Restrict)
  parentBusinessUnit   BusinessUnit?  @relation("BusinessUnitHierarchy", fields: [parentBusinessUnitId, tenantId], references: [id, tenantId], onDelete: Restrict)
  childBusinessUnits   BusinessUnit[] @relation("BusinessUnitHierarchy")
  users                User[]
  employees            Employee[]
  projects             Project[]
  timesheets           Timesheet[]
  payrollCycles        PayrollCycle[]
  processingCycles     ProcessingCycle[]

  @@unique([id, tenantId])
  @@unique([tenantId, organizationId, name])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, organizationId])
  @@index([tenantId, parentBusinessUnitId])
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String
  name            String
  key             String
  roleType        RoleType         @default(CUSTOM)
  accessLevel     RoleAccessLevel  @default(USER)
  description     String?
  isSystem        Boolean          @default(false)
  isEditable       Boolean          @default(true)
  isCloneable      Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     String?
  updatedById     String?
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  rolePrivileges  RolePrivilege[]
  miscPermissions RoleMiscPermission[]

  @@unique([tenantId, key])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isSystem])
  @@index([tenantId, roleType])
}

model Permission {
  id              String           @id @default(uuid())
  tenantId        String
  name            String
  key             String
  description     String?
