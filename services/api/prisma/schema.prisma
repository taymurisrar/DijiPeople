// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ONBOARDING
  ACTIVE
  SUSPENDED
  CHURNED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum DiscountType {
  NONE
  PERCENTAGE
  FLAT
}

enum CustomerAccountStatus {
  LEAD
  PROSPECT
  ONBOARDING
  ACTIVE
  SUSPENDED
  CHURNED
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  CLOSED_LOST
  ARCHIVED
}

enum CustomerOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  AWAITING_CUSTOMER_INPUT
  PENDING_PAYMENT
  READY_FOR_TENANT_CREATION
  COMPLETED
  BLOCKED
  CANCELED
}

enum TenantFeatureSource {
  PLAN
  MANUAL
  PROMOTIONAL
  CUSTOM
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  BANK
  MANUAL
  OTHER
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
}

enum DocumentEntityType {
  EMPLOYEE
  LEAVE_REQUEST
  PAYROLL_RECORD
  CANDIDATE
  ONBOARDING_RECORD
  TENANT
  INVOICE
  POLICY
  OTHER
}

enum UserStatus {
