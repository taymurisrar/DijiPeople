  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  @@index([key])
}

model Invoice {
  id                String          @id @default(uuid())
  tenantId          String
  subscriptionId    String
  invoiceNumber     String
  amount            Decimal         @db.Decimal(12, 2)
  currency          String
  issueDate         DateTime
  dueDate           DateTime
  status            InvoiceStatus   @default(DRAFT)
  stripeInvoiceId   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdById       String?
  updatedById       String?
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription      Subscription    @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payments          Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status])
  @@index([subscriptionId])
}

model Payment {
  id                   String        @id @default(uuid())
  tenantId             String
  subscriptionId       String
  invoiceId            String?
  amount               Decimal       @db.Decimal(12, 2)
  currency             String
  paymentMethod        PaymentMethod
  status               PaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  paidAt               DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  createdById          String?
  updatedById          String?
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription         Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoice              Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([subscriptionId])
  @@index([invoiceId])
}

model PayrollCycle {
  id          String             @id @default(uuid())
  tenantId    String
  businessUnitId String?
  processingCycleId String?
  periodStart DateTime
  periodEnd   DateTime
  runDate     DateTime?
  status      PayrollCycleStatus @default(DRAFT)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdById String?
  updatedById String?
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessUnit BusinessUnit?     @relation(fields: [businessUnitId, tenantId], references: [id, tenantId], onDelete: Restrict)
  processingCycle ProcessingCycle? @relation(fields: [processingCycleId], references: [id], onDelete: SetNull)
  records     PayrollRecord[]

  @@unique([tenantId, businessUnitId, periodStart, periodEnd])
  @@index([tenantId])
  @@index([tenantId, businessUnitId])
  @@index([tenantId, processingCycleId])
  @@index([tenantId, status])
  @@index([tenantId, periodStart, periodEnd])
}

model ProcessingCycle {
  id              String                @id @default(uuid())
  tenantId        String
  businessUnitId  String?
  name            String
  startDate       DateTime
  endDate         DateTime
  cycleType       ProcessingCycleType   @default(MONTHLY)
  status          ProcessingCycleStatus @default(OPEN)
  lockedAt        DateTime?
  lockedByUserId  String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  createdById     String?
  updatedById     String?
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessUnit    BusinessUnit?         @relation(fields: [businessUnitId, tenantId], references: [id, tenantId], onDelete: Restrict)
  lockedByUser    User?                 @relation("ProcessingCycleLocker", fields: [lockedByUserId], references: [id], onDelete: SetNull)
  timesheets      Timesheet[]
  payrollCycles   PayrollCycle[]

  @@unique([tenantId, businessUnitId, startDate, endDate, cycleType])
  @@index([tenantId])
  @@index([tenantId, businessUnitId])
  @@index([tenantId, status])
  @@index([tenantId, startDate, endDate])
}

model PayrollRecord {
  id             String              @id @default(uuid())
  tenantId       String
  employeeId     String
  payrollCycleId String
  gross          Decimal             @db.Decimal(12, 2)
  deductions     Decimal             @db.Decimal(12, 2)
  net            Decimal             @db.Decimal(12, 2)
  status         PayrollRecordStatus @default(DRAFT)
  lineItems      Json?
  sourceTimesheetIds Json?
  timesheetSummary Json?
  adjustments    Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdById    String?
  updatedById    String?
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee       Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollCycle   PayrollCycle        @relation(fields: [payrollCycleId], references: [id], onDelete: Cascade)

  @@unique([payrollCycleId, employeeId])
  @@index([tenantId])
  @@index([tenantId, payrollCycleId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
}

model SalaryComponent {
  id            String              @id @default(uuid())
  tenantId      String
  name          String
  code          String
  type          SalaryComponentType
  defaultAmount Decimal?            @db.Decimal(12, 2)
  description   String?
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  createdById   String?
  updatedById   String?
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, type, isActive])
}

model EmployeeCompensation {
  id            String       @id @default(uuid())
  tenantId      String
  employeeId    String
  basicSalary   Decimal      @db.Decimal(12, 2)
  payFrequency  PayFrequency
  effectiveDate DateTime
  endDate       DateTime?
  currency      String       @default("USD")
  payrollStatus PayrollStatus @default(ACTIVE)
  payrollGroup  String?
  paymentMode   PaymentMode?
  bankName      String?
  bankAccountTitle String?
  bankAccountNumber String?
  bankIban      String?
  bankRoutingNumber String?
  taxIdentifier String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdById   String?
  updatedById   String?
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, effectiveDate])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, effectiveDate])
}

model AuditLog {
  id             String   @id @default(uuid())
  tenantId       String
  actorUserId    String?
  action         String
  entityType     String
  entityId       String
  beforeSnapshot Json?
  afterSnapshot  Json?
  createdAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser      User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, action, createdAt])
  @@index([tenantId, entityType, createdAt])
  @@index([tenantId, actorUserId, createdAt])
}

enum ModuleViewType {
  system
  custom
}

enum ModuleViewVisibilityScope {
  tenant
  role
  user
}

enum CustomizationFieldDataType {
  text
  textarea
  number
  decimal
  date
  datetime
  boolean
  select
  multiselect
  lookup
  email
  phone
  url
  currency
}

enum CustomizationFormType {
  main
  quick
  create
  edit
}

enum CustomizationPublishStatus {
  draft
  published
  failed
}

model ModuleView {
  id              String                    @id @default(uuid())
  tenantId        String
  moduleKey       String
  name            String
  slug            String
  type            ModuleViewType            @default(custom)
  isDefault       Boolean                   @default(false)
  isShared        Boolean                   @default(false)
  createdByUserId String?
  visibilityScope ModuleViewVisibilityScope @default(tenant)
  allowedRoleKeys Json?
  allowedUserIds  Json?
  configJson      Json
  sortOrder       Int                       @default(0)
  isActive        Boolean                   @default(true)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([tenantId, moduleKey])
  @@index([tenantId, moduleKey, isActive])
  @@index([tenantId, moduleKey, isDefault])
  @@unique([tenantId, moduleKey, slug])
}

model CustomizationTable {
  id                String   @id @default(uuid())
  tenantId          String
  tableKey          String
  systemName        String
  displayName       String
  pluralDisplayName String
  description       String?
  icon              String?
  isCustomizable    Boolean  @default(true)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  columns           CustomizationColumn[]
  views             CustomizationView[]
  forms             CustomizationForm[]

  @@unique([tenantId, tableKey])
  @@index([tenantId, isActive])
  @@index([tenantId, isCustomizable])
}

model CustomizationColumn {
  id                   String                 @id @default(uuid())
  tenantId             String
  tableId              String
  columnKey            String
  systemName           String
  displayName          String
  dataType             CustomizationFieldDataType
  fieldType            CustomizationFieldDataType
  isSystem             Boolean                @default(false)
  isRequired           Boolean                @default(false)
  isSearchable         Boolean                @default(false)
  isSortable           Boolean                @default(false)
  isVisible            Boolean                @default(true)
  isReadOnly           Boolean                @default(false)
  maxLength            Int?
  minValue             Decimal?
  maxValue             Decimal?
  defaultValue         String?
  lookupTargetTableKey String?
  optionSetJson        Json?
  validationJson       Json?
  sortOrder            Int                    @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table                CustomizationTable     @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tenantId, tableId, columnKey])
  @@index([tenantId, tableId])
  @@index([tenantId, isSystem])
  @@index([tenantId, tableId, sortOrder])
}

model CustomizationView {
  id                String                    @id @default(uuid())
  tenantId          String
  tableId           String
  viewKey           String
  name              String
  description       String?
  type              ModuleViewType            @default(custom)
  isDefault         Boolean                   @default(false)
  isHidden          Boolean                   @default(false)
  columnsJson       Json
  filtersJson       Json?
  sortingJson       Json?
  visibilityScope   ModuleViewVisibilityScope @default(tenant)
  createdByUserId   String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table             CustomizationTable        @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tenantId, tableId, viewKey])
  @@index([tenantId, tableId])
  @@index([tenantId, tableId, isDefault])
  @@index([tenantId, tableId, isHidden])
}

model CustomizationForm {
  id              String             @id @default(uuid())
  tenantId        String
  tableId         String
  formKey         String
  name            String
  description     String?
  type            CustomizationFormType @default(main)
  isDefault       Boolean            @default(false)
  isActive        Boolean            @default(true)
  layoutJson      Json
  createdByUserId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table           CustomizationTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tenantId, tableId, formKey])
  @@index([tenantId, tableId])
  @@index([tenantId, tableId, isActive])
  @@index([tenantId, tableId, isDefault])
}

model CustomizationPublishSnapshot {
  id                String                     @id @default(uuid())
  tenantId          String
  version           Int
  status            CustomizationPublishStatus @default(draft)
  publishedByUserId String?
  publishedAt       DateTime?
  snapshotJson      Json
  createdAt         DateTime                   @default(now())

  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, version])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}
