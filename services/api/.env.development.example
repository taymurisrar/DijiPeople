# Development API environment. Copy to services/api/.env.
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000/api
API_ORIGIN=http://localhost:4000
API_DEFAULT_TENANT_SLUG=
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/dijipeople

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:5173
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-DijiPeople-App,X-DijiPeople-Client,X-Client-Id,X-Tenant-Slug,X-Requested-With,X-Trace-Id,X-Request-Id
CORS_ALLOWED_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOW_CREDENTIALS=true

ADMIN_APP_URL=http://localhost:3002
WEB_APP_URL=http://localhost:3001
LANDING_APP_URL=http://localhost:3000
ACCOUNT_ACTIVATION_LINK_BASE_URL=http://localhost:3001/account/activate
PASSWORD_RESET_LINK_BASE_URL=http://localhost:3001/auth/reset-password

JWT_ACCESS_SECRET=replace-with-local-32-char-access-secret
JWT_REFRESH_SECRET=replace-with-local-32-char-refresh-secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=15m
AUTH_REFRESH_TOKEN_TTL_SECONDS=1h
AUTH_IDLE_SESSION_TIMEOUT_SECONDS=1h
AUTH_ABSOLUTE_SESSION_TIMEOUT_SECONDS=8h
AUTH_REFRESH_ROTATION_ENABLED=true

ADMIN_JWT_ACCESS_SECRET=replace-with-local-admin-access-secret-32
ADMIN_JWT_REFRESH_SECRET=replace-with-local-admin-refresh-secret-32
WEB_JWT_ACCESS_SECRET=replace-with-local-web-access-secret-32
WEB_JWT_REFRESH_SECRET=replace-with-local-web-refresh-secret-32
AGENT_JWT_ACCESS_SECRET=replace-with-local-agent-access-secret-32
AGENT_JWT_REFRESH_SECRET=replace-with-local-agent-refresh-secret-32
AUTH_AGENT_ACCESS_TOKEN_TTL_SECONDS=15m
AUTH_AGENT_REFRESH_TOKEN_TTL_SECONDS=8h
AUTH_AGENT_IDLE_SESSION_TIMEOUT_SECONDS=8h
AUTH_AGENT_ABSOLUTE_SESSION_TIMEOUT_SECONDS=30d

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
ADMIN_COOKIE_DOMAIN=
WEB_COOKIE_DOMAIN=
ADMIN_ACCESS_TOKEN_COOKIE=admin_access_token
ADMIN_REFRESH_TOKEN_COOKIE=admin_refresh_token
WEB_ACCESS_TOKEN_COOKIE=web_access_token
WEB_REFRESH_TOKEN_COOKIE=web_refresh_token
AGENT_ACCESS_TOKEN_COOKIE=agent_access_token
AGENT_REFRESH_TOKEN_COOKIE=agent_refresh_token

EXPOSE_DEV_AUTH_LINKS=true
ENABLE_EMAILS=true
ENABLE_NOTIFICATIONS=true
ENABLE_ACCOUNT_ACTIVATION_EMAIL=true
ENABLE_PASSWORD_RESET_EMAIL=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@localhost
SMTP_FROM_NAME=DijiPeople
LOG_LEVEL=debug
REQUEST_LOGGING_ENABLED=true
ERROR_LOG_ENABLED=true
ERROR_LOG_STORAGE=database
ERROR_LOG_RETENTION_DAYS=90
ERROR_LOG_INCLUDE_STACK=true
ERROR_LOG_INCLUDE_REQUEST_BODY=false
ERROR_LOG_EXPOSE_STACK_TO_SYSTEM_CUSTOMIZER=true
ERROR_LOG_DOWNLOAD_ROLE=System Customizer
ERROR_TRACE_HEADER=x-trace-id
ERROR_SUPPORT_MESSAGE="Share this reference ID with support if the issue continues."
ERROR_VERBOSE_RESPONSE=false
