# Production API environment for Render.
# SECURITY: The previously exposed Neon DATABASE_URL must be rotated. Store the rotated value only in Render env vars.
NODE_ENV=production
PORT=4000
API_BASE_URL=https://dijipeople.onrender.com/api
API_ORIGIN=https://dijipeople.onrender.com
DATABASE_URL=postgresql://ROTATED_USER:ROTATED_PASSWORD@ROTATED_HOST/ROTATED_DB?sslmode=require

CORS_ALLOWED_ORIGINS=https://diji-people-admin.vercel.app,https://diji-people-web.vercel.app,https://diji-people-landing.vercel.app
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-DijiPeople-App,X-DijiPeople-Client,X-Client-Id,X-Tenant-Slug,X-Requested-With,X-Trace-Id,X-Request-Id
CORS_ALLOWED_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOW_CREDENTIALS=true

ADMIN_APP_URL=https://diji-people-admin.vercel.app
WEB_APP_URL=https://diji-people-web.vercel.app
LANDING_APP_URL=https://diji-people-landing.vercel.app
ACCOUNT_ACTIVATION_LINK_BASE_URL=https://diji-people-web.vercel.app/account/activate
PASSWORD_RESET_LINK_BASE_URL=https://diji-people-web.vercel.app/auth/reset-password

JWT_ACCESS_SECRET=replace-with-production-global-access-secret-32-plus
JWT_REFRESH_SECRET=replace-with-production-global-refresh-secret-32-plus
AUTH_ACCESS_TOKEN_TTL_SECONDS=15m
AUTH_REFRESH_TOKEN_TTL_SECONDS=1h
AUTH_IDLE_SESSION_TIMEOUT_SECONDS=1h
AUTH_ABSOLUTE_SESSION_TIMEOUT_SECONDS=8h
AUTH_REFRESH_ROTATION_ENABLED=true

ADMIN_JWT_ACCESS_SECRET=replace-with-production-admin-access-secret-32-plus
ADMIN_JWT_REFRESH_SECRET=replace-with-production-admin-refresh-secret-32-plus
ADMIN_JWT_ACCESS_TTL=15m
ADMIN_JWT_REFRESH_TTL=1h
AUTH_ADMIN_ACCESS_TOKEN_TTL_SECONDS=15m
AUTH_ADMIN_REFRESH_TOKEN_TTL_SECONDS=1h

WEB_JWT_ACCESS_SECRET=replace-with-production-web-access-secret-32-plus
WEB_JWT_REFRESH_SECRET=replace-with-production-web-refresh-secret-32-plus
WEB_JWT_ACCESS_TTL=15m
WEB_JWT_REFRESH_TTL=1h
AUTH_WEB_ACCESS_TOKEN_TTL_SECONDS=15m
AUTH_WEB_REFRESH_TOKEN_TTL_SECONDS=1h

AGENT_JWT_ACCESS_SECRET=replace-with-production-agent-access-secret-32-plus
AGENT_JWT_REFRESH_SECRET=replace-with-production-agent-refresh-secret-32-plus
AGENT_JWT_ACCESS_TTL=15m
AGENT_JWT_REFRESH_TTL=30d
AUTH_AGENT_ACCESS_TOKEN_TTL_SECONDS=15m
AUTH_AGENT_REFRESH_TOKEN_TTL_SECONDS=30d
AUTH_AGENT_IDLE_SESSION_TIMEOUT_SECONDS=12h
AUTH_AGENT_ABSOLUTE_SESSION_TIMEOUT_SECONDS=30d

COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
ADMIN_COOKIE_DOMAIN=
WEB_COOKIE_DOMAIN=
ACCESS_TOKEN_COOKIE=web_access_token
REFRESH_TOKEN_COOKIE=web_refresh_token
ADMIN_ACCESS_TOKEN_COOKIE=admin_access_token
ADMIN_REFRESH_TOKEN_COOKIE=admin_refresh_token
WEB_ACCESS_TOKEN_COOKIE=web_access_token
WEB_REFRESH_TOKEN_COOKIE=web_refresh_token
AGENT_ACCESS_TOKEN_COOKIE=agent_access_token
AGENT_REFRESH_TOKEN_COOKIE=agent_refresh_token

EXPOSE_DEV_AUTH_LINKS=false
ENABLE_EMAILS=true
ENABLE_NOTIFICATIONS=true
ENABLE_ACCOUNT_ACTIVATION_EMAIL=true
ENABLE_PASSWORD_RESET_EMAIL=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM_EMAIL=no-reply@dijipeople.example
SMTP_FROM_NAME=DijiPeople

LOG_LEVEL=info
REQUEST_LOGGING_ENABLED=true
ERROR_LOG_ENABLED=true
ERROR_LOG_STORAGE=database
ERROR_LOG_RETENTION_DAYS=90
ERROR_LOG_INCLUDE_STACK=true
ERROR_LOG_INCLUDE_REQUEST_BODY=false
ERROR_LOG_EXPOSE_STACK_TO_SYSTEM_CUSTOMIZER=true
ERROR_LOG_DOWNLOAD_ROLE=System Customizer
ERROR_TRACE_HEADER=x-trace-id
ERROR_SUPPORT_MESSAGE="Share this reference ID with support if the issue continues."
ERROR_VERBOSE_RESPONSE=false
