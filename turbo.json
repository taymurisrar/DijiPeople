{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "APP_ENV",
    "DIJIPEOPLE_ENV",

    "DATABASE_URL",

    "JWT_ACCESS_SECRET",
    "JWT_REFRESH_SECRET",
    "JWT_ACCESS_TTL",
    "JWT_REFRESH_TTL",

    "WEB_JWT_ACCESS_SECRET",
    "WEB_JWT_REFRESH_SECRET",
    "WEB_JWT_ACCESS_TTL",
    "WEB_JWT_REFRESH_TTL",

    "ADMIN_JWT_ACCESS_SECRET",
    "ADMIN_JWT_REFRESH_SECRET",
    "ADMIN_JWT_ACCESS_TTL",
    "ADMIN_JWT_REFRESH_TTL",

    "AGENT_JWT_ACCESS_SECRET",
    "AGENT_JWT_REFRESH_SECRET",
    "AGENT_JWT_ACCESS_TTL",
    "AGENT_JWT_REFRESH_TTL",

    "AUTH_ACCESS_TOKEN_TTL_SECONDS",
    "AUTH_REFRESH_TOKEN_TTL_SECONDS",
    "AUTH_IDLE_SESSION_TIMEOUT_SECONDS",
    "AUTH_ABSOLUTE_SESSION_TIMEOUT_SECONDS",
    "AUTH_SESSION_ACTIVITY_THROTTLE_SECONDS",
    "AUTH_REFRESH_ROTATION_ENABLED",

    "AUTH_WEB_ACCESS_TOKEN_TTL_SECONDS",
    "AUTH_WEB_REFRESH_TOKEN_TTL_SECONDS",

    "AUTH_ADMIN_ACCESS_TOKEN_TTL_SECONDS",
    "AUTH_ADMIN_REFRESH_TOKEN_TTL_SECONDS",

    "AUTH_AGENT_ACCESS_TOKEN_TTL_SECONDS",
    "AUTH_AGENT_REFRESH_TOKEN_TTL_SECONDS",
    "AUTH_AGENT_IDLE_SESSION_TIMEOUT_SECONDS",
    "AUTH_AGENT_ABSOLUTE_SESSION_TIMEOUT_SECONDS",

    "AUTH_CLIENT_ID",

    "API_BASE_URL",
    "API_ORIGIN",
    "API_URL",

    "CORS_ALLOWED_ORIGINS",

    "NEXT_PUBLIC_API_BASE_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_API_ORIGIN",

    "NEXT_PUBLIC_APP_ENV",
    "NEXT_PUBLIC_APP_NAME",
    "NEXT_PUBLIC_APP_ORIGIN",

    "NEXT_PUBLIC_LANDING_URL",
    "NEXT_PUBLIC_WEB_URL",
    "NEXT_PUBLIC_ADMIN_URL",

    "NEXT_PUBLIC_LANDING_APP_URL",
    "NEXT_PUBLIC_WEB_APP_URL",
    "NEXT_PUBLIC_ADMIN_APP_URL",

    "LANDING_APP_URL",
    "WEB_APP_URL",
    "ADMIN_APP_URL",

    "NEXT_PUBLIC_AUTH_CLIENT_ID",

    "NEXT_PUBLIC_TENANT_SLUG",
    "TENANT_SLUG",

    "ACCESS_TOKEN_COOKIE",
    "REFRESH_TOKEN_COOKIE",

    "WEB_ACCESS_TOKEN_COOKIE",
    "WEB_REFRESH_TOKEN_COOKIE",

    "ADMIN_ACCESS_TOKEN_COOKIE",
    "ADMIN_REFRESH_TOKEN_COOKIE",

    "AGENT_ACCESS_TOKEN_COOKIE",
    "AGENT_REFRESH_TOKEN_COOKIE",

    "AUTH_COOKIE_DOMAIN",
    "COOKIE_DOMAIN",
    "COOKIE_SECURE",
    "COOKIE_SAME_SITE",

    "SESSION_IDLE_TIMEOUT_SECONDS",
    "SESSION_ABSOLUTE_TIMEOUT_SECONDS",
    "SESSION_REFRESH_THRESHOLD_SECONDS",

    "USE_ENTITY_DATA_API",
    "EXPOSE_DEV_AUTH_LINKS",

    "NEXT_PUBLIC_DEFAULT_BRAND_NAME",
    "NEXT_PUBLIC_DEFAULT_BRAND_SHORT_NAME",

    "NEXT_PUBLIC_ENVIRONMENT",
    "NEXT_PUBLIC_ENABLE_SECURE_AUTH",
    "NEXT_PUBLIC_ENABLE_CLIENT_LOGS",
    "NEXT_PUBLIC_SUPPORT_EMAIL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}